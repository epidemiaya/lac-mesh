{
  "appId": "uk.lac.mesh",
  "appName": "LAC Mesh",
  "webDir": "dist",
  "bundledWebRuntime": false,
  "plugins": {
    "BluetoothLe": {
      "displayStrings": {
        "scanning": "Scanning for LAC mesh nodes...",
        "cancel": "Cancel",
